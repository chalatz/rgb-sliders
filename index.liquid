---
layout: layout.liquid
title: RGB Sliders
---
<h1 class="heading">RGB Sliders</h1>

<div class="grid">
    <div class="row">
        <span class="index index--red">0</span>
        <span class="slider-wrapper">
            {% comment %} <span id="bubble--red" class="bubble bubble--red">0</span> {% endcomment %}
            <input type="range" min="0" max="255" value="0" class="slider slider--red" data-target="red" id="slider--red">
        </span>
        <span class="result result--red"></span>
    </div>
    <div class="row">
        <span class="index index--green">0</span>
        <span class="slider-wrapper">
            {% comment %} <span id="bubble--green" class="bubble bubble--green">0</span> {% endcomment %}
            <input type="range" min="0" max="255" value="0" class="slider slider--green" data-target="green" id="slider--green">
        </span>
        <span class="result result--green"></span>
    </div>
    <div class="row">
        <span class="index index--blue">0</span>
        <span class="slider-wrapper">
            {% comment %} <span id="bubble--blue" class="bubble bubble--blue">0</span> {% endcomment %}
            <input type="range" min="0" max="255" value="0" class="slider slider--blue" data-target="blue" id="slider--blue">
        </span>
        <span class="result result--blue"></span>
    </div>

    <div class="rgb-result-wrapper">
        <div class="rgb-result"></div>
    </div>
</div>